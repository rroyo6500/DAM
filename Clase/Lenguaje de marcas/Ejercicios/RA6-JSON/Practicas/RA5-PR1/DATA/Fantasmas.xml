            </prueba>
            <prueba>
                <nombre tipo="Ghost Orbs"/>
                <descripcion>Luces flotantes en cámara.</descripcion>
            </prueba>
            <prueba>
                <nombre tipo="D.O.T.S."/>
                <descripcion>Silueta visible en la luz D.O.T.S.</descripcion>
            </prueba>
        </pruebas>
        <habilidad>Se vuelve extremadamente rápido cerca de aparatos electrónicos encendidos.</habilidad>
        <cordura>65</cordura>
        <velocidad_base unidad="m/s">2</velocidad_base>
        <velocidad_maxima unidad="m/s">4</velocidad_maxima>
        <velocidad_minima unidad="m/s">2</velocidad_minima>
