<!ELEMENT esdeveniment (obra+)>
<!ELEMENT obra (director, nom, descripcio?)>
<!ATTLIST obra 
    id ID #REQUIRED
    pais CDATA #REQUIRED
>

<!ELEMENT director (#PCDATA)>
<!ELEMENT nom (#PCDATA)>
