<ejemplos>

    <!-- etiqueta.principal>setiqueta#$*2[tipoEtiqueta=secundaria]>setiqueta[tipoEtiqueta=terciaria]{Etiqueta Terciaria} -->
    <etiqueta class="principal">
        <setiqueta id="1" tipoEtiqueta="secundaria">
            <setiqueta tipoEtiqueta="terciaria">Etiqueta Terciaria</setiqueta>
        </setiqueta>
        <setiqueta id="2" tipoEtiqueta="secundaria">
            <setiqueta tipoEtiqueta="terciaria">Etiqueta Terciaria</setiqueta>
        </setiqueta>
    </etiqueta>

    <!-- etiqueta.principal>(setiqueta#1[tipoEtiqueta=secundaria]>setiqueta[tipoEtiqueta=terciaria]{Etiqueta Terciaria})+setiqueta2#2[tipoEtiqueta=secundaria] -->
    <etiqueta class="principal">
        <setiqueta id="1" tipoEtiqueta="secundaria">
            <setiqueta tipoEtiqueta="terciaria">Etiqueta Terciaria</setiqueta>
        </setiqueta>
        <setiqueta2 id="2" tipoEtiqueta="secundaria"></setiqueta2>
    </etiqueta>

</ejemplos>
